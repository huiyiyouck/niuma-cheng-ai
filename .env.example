HOST=127.0.0.1
PORT=8100

# LLM 多 provider fallback（推荐，ADR-0002）
# JSON 数组，每项含 name/base_url/api_key_env/model（可选 timeout_ms/temperature/
# supports_response_format）。key 通过 api_key_env 指向下方环境变量，勿写入 JSON。
# 生产至少配置 2 个 provider（DevOps 发布检查项2）。
LLM_PROVIDERS_JSON=[{"name":"primary","base_url":"https://api.example.com/v1","api_key_env":"OPENAI_API_KEY","model":"model-a"},{"name":"backup","base_url":"https://api.backup.com/v1","api_key_env":"BACKUP_OPENAI_API_KEY","model":"model-b"}]

# provider api key（被 LLM_PROVIDERS_JSON 的 api_key_env 引用）
OPENAI_API_KEY=
BACKUP_OPENAI_API_KEY=

# 单 provider 兼容路径（未设 LLM_PROVIDERS_JSON 时回退，便于本地冒烟）
OPENAI_BASE_URL=https://api.openai.com/v1
L1_LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=60000

# 外部搜索（Web 搜索 ai 直连 Tavily，CN-001；未配置时降级不阻塞）
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# 库内检索（主动 KB search，CN-002；ai 回调 xiaobao /v1/kb-search，契约 kb-search.md v1）
# 未配置 KB_SEARCH_URL 时不触发主动 KB 检索、以 needs_context 标记缺口，不阻塞主流程。
KB_SEARCH_URL=http://127.0.0.1:8001/v1/kb-search
KB_ADMIN_TOKEN=
